# Runtime mode: local | public_demo | private_owner
DEPLOYMENT_MODE=local
# Legacy compatibility flag. Keep false unless using the existing public Demo deployment.
PUBLIC_DEMO_MODE=false
DATA_DIR=data

# Private single-owner mode (required only when DEPLOYMENT_MODE=private_owner)
PERSISTENT_DATA_ACKNOWLEDGED=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=
OWNER_GITHUB_USER_ID=
SESSION_SECRET=
SESSION_COOKIE_SECURE=true
SESSION_TTL_HOURS=720

# Optional scheduled backups. Relative BACKUP_DIR values live below DATA_DIR.
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_COUNT=7
BACKUP_DIR=backups

# Search provider
SEARCH_PROVIDER=exa
EXA_API_KEY=

# Chat LLM provider
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
CHAT_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=2

# Optional bounded LLM review for guided source candidates.
CANDIDATE_LLM_ASSESSMENT_ENABLED=true
CANDIDATE_LLM_TIMEOUT_SECONDS=45
CANDIDATE_LLM_MIN_CONFIDENCE=0.60
CANDIDATE_LLM_MAX_TOKENS=4000

# Embedding provider
EMBEDDING_PROVIDER=dashscope
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
